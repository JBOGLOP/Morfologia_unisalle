<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Generalidades de Anatomía Humana</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --amber:     #C8762A;
      --amber-dk:  #8A4D10;
      --amber-lt:  #F5D9A8;
      --cream:     #FAF6EE;
      --parchment: #F0E8D5;
      --ink:       #1C1610;
      --ink-soft:  #3D3020;
      --ink-muted: #7A6A50;
      --accent:    #2D6A7F;
      --accent-lt: #D0EAF2;
      --rule:      #D4BB8A;
      --white:     #FFFFFF;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--ink);
      font-family: 'Source Serif 4', Georgia, serif;
      font-weight: 300;
      line-height: 1.8;
      font-size: 17px;
    }

    /* ──────────────── NAVIGATION ──────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: rgba(28, 22, 16, 0.96);
      backdrop-filter: blur(10px);
      border-bottom: 2px solid var(--amber);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 58px;
    }

    .nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      color: var(--amber-lt);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 0.2rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--ink-muted);
      text-decoration: none;
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.3rem 0.75rem;
      border-radius: 3px;
      transition: all 0.2s;
    }

    .nav-links a:hover {
      color: var(--amber-lt);
      background: rgba(200,118,42,0.15);
    }

    /* ──────────────── HERO ──────────────── */
    .hero {
      min-height: 100vh;
      background:
        radial-gradient(ellipse 80% 60% at 60% 40%, rgba(200,118,42,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 50% 80% at 10% 70%, rgba(45,106,127,0.08) 0%, transparent 60%),
        var(--ink);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(200,118,42,0.06) 59px, rgba(200,118,42,0.06) 60px),
        repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(200,118,42,0.04) 59px, rgba(200,118,42,0.04) 60px);
      pointer-events: none;
    }

    .hero-inner { max-width: 820px; position: relative; }

    .hero-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1.5rem;
      display: block;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 6vw, 4.8rem);
      font-weight: 700;
      color: var(--cream);
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--amber-lt);
    }

    .hero-subtitle {
      font-size: 1.05rem;
      color: rgba(250,246,238,0.55);
      margin-top: 1.5rem;
      font-style: italic;
      letter-spacing: 0.02em;
    }

    .hero-rule {
      width: 80px;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--amber), transparent);
      margin: 2rem auto;
    }

    .hero-chapters {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 2.5rem;
    }

    .chapter-pill {
      background: rgba(200,118,42,0.15);
      border: 1px solid rgba(200,118,42,0.4);
      color: var(--amber-lt);
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      padding: 0.45rem 1.1rem;
      border-radius: 50px;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.25s;
    }

    .chapter-pill:hover {
      background: rgba(200,118,42,0.3);
      transform: translateY(-2px);
    }

    /* ──────────────── SECTIONS ──────────────── */
    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 5rem 2.5rem;
    }

    .section + .section { border-top: 1px solid var(--rule); }

    .section-band {
      background: var(--parchment);
    }

    .section-dark {
      background: var(--ink);
      color: var(--cream);
      max-width: 100%;
      padding: 5rem 0;
    }

    .section-dark .section-inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 2.5rem;
    }

    /* chapter heading */
    .ch-num {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      color: var(--amber);
      text-transform: uppercase;
      display: block;
      margin-bottom: 0.5rem;
    }

    .ch-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.9rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.4rem;
    }

    .ch-rule {
      width: 50px;
      height: 3px;
      background: var(--amber);
      margin: 1.4rem 0 2.2rem;
      border-radius: 2px;
    }

    /* section headings */
    h3.topic {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--amber-dk);
      margin: 2.5rem 0 0.8rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--rule);
    }

    .section-dark h3.topic { color: var(--amber-lt); border-bottom-color: rgba(200,118,42,0.4); }

    h4.subtopic {
      font-family: 'Source Serif 4', serif;
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--ink-soft);
      margin: 1.6rem 0 0.5rem;
    }

    .section-dark h4.subtopic { color: var(--amber-lt); }

    p { margin-bottom: 1rem; }

    /* ──────────────── CALLOUT BOXES ──────────────── */
    .callout {
      background: var(--parchment);
      border-left: 4px solid var(--amber);
      border-radius: 0 8px 8px 0;
      padding: 1.2rem 1.5rem;
      margin: 1.8rem 0;
      font-size: 0.96rem;
    }

    .callout strong { color: var(--amber-dk); }

    .callout-accent {
      background: var(--accent-lt);
      border-left-color: var(--accent);
    }

    .callout-accent strong { color: var(--accent); }

    .section-dark .callout {
      background: rgba(200,118,42,0.1);
      border-left-color: var(--amber);
    }

    /* ──────────────── GRID CARDS ──────────────── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.2rem;
      margin: 1.8rem 0;
    }

    .card {
      background: var(--white);
      border: 1px solid var(--rule);
      border-radius: 10px;
      padding: 1.3rem 1.4rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }

    .card-icon {
      font-size: 1.6rem;
      margin-bottom: 0.7rem;
      display: block;
    }

    .card h5 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--amber-dk);
      margin-bottom: 0.5rem;
    }

    .card p { font-size: 0.9rem; margin: 0; color: var(--ink-soft); }

    /* dark-bg card */
    .card-dk {
      background: rgba(255,255,255,0.05);
      border-color: rgba(200,118,42,0.25);
    }

    .card-dk h5 { color: var(--amber-lt); }
    .card-dk p  { color: rgba(250,246,238,0.7); }

    /* ──────────────── DEFINITION LIST ──────────────── */
    .def-list { margin: 1rem 0 1.5rem; }

    .def-item {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 0.5rem 1.5rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(212,187,138,0.4);
      font-size: 0.95rem;
    }

    .def-item:last-child { border-bottom: none; }

    .def-term {
      font-family: 'DM Mono', monospace;
      font-size: 0.82rem;
      color: var(--amber-dk);
      font-weight: 500;
      align-self: start;
      padding-top: 0.15rem;
      letter-spacing: 0.03em;
    }

    .section-dark .def-term { color: var(--amber-lt); }
    .section-dark .def-item { border-bottom-color: rgba(200,118,42,0.2); }

    /* ──────────────── TABLE ──────────────── */
    .anat-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 1.8rem 0;
      background: var(--white);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .anat-table thead tr {
      background: var(--amber);
      color: var(--white);
    }

    .anat-table thead th {
      padding: 0.9rem 1.1rem;
      text-align: left;
      font-family: 'DM Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .anat-table tbody tr:nth-child(even) { background: var(--parchment); }
    .anat-table tbody tr:hover { background: var(--amber-lt); }

    .anat-table td {
      padding: 0.75rem 1.1rem;
      border-bottom: 1px solid rgba(212,187,138,0.35);
      vertical-align: top;
      line-height: 1.5;
    }

    .anat-table td:first-child { font-weight: 600; color: var(--amber-dk); }

    /* ──────────────── TERM HIGHLIGHT ──────────────── */
    .term {
      color: var(--amber-dk);
      font-weight: 600;
    }

    .section-dark .term { color: var(--amber-lt); }

    /* ──────────────── TWO-COL LAYOUT ──────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin: 1.5rem 0;
    }

    @media (max-width: 640px) {
      .two-col { grid-template-columns: 1fr; }
      .def-item { grid-template-columns: 1fr; gap: 0.2rem; }
      .nav-links { display: none; }
      .card-grid { grid-template-columns: 1fr; }
    }

    /* ──────────────── BADGE ──────────────── */
    .badge {
      display: inline-block;
      background: var(--amber);
      color: var(--white);
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      padding: 0.15rem 0.6rem;
      border-radius: 4px;
      text-transform: uppercase;
      vertical-align: middle;
      margin-left: 0.4rem;
    }

    .badge-blue {
      background: var(--accent);
    }

    /* ──────────────── FOOTNOTE ──────────────── */
    .footnote {
      font-size: 0.82rem;
      color: var(--ink-muted);
      font-style: italic;
      border-top: 1px solid var(--rule);
      margin-top: 3rem;
      padding-top: 1rem;
    }

    /* ──────────────── SCROLL ANIMATION ──────────────── */
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: none;
    }
  </style>
</head>
